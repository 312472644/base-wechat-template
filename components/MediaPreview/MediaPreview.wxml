<!--components/MediaPreview/MediaPreview.wxml-->
<view class="media-preview">
  <form-item title="{{title}}" arrow="{{false}}" />
  <view class="media-content">
    <view wx:for="{{mediaList}}" wx:key="index" class="media-item" data-item="{{item}}" bind:tap="handlePreview">
      <t-image wx:if="{{item.isImage}}" shape="round" src="{{item.url}}" style="width: 100%; height: 140rpx;" />
      <view wx:if="{{item.isVideo}}" class="video">
        <t-icon name="play-circle" color="#333" size="48rpx" />
      </view>
    </view>
  </view>
</view>